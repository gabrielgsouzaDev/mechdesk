{
  "name": "lucianofreios",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de gestão de oficina e fiscal — Luciano Freios",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "db:generate": "npm run generate -w @lf/db",
    "db:migrate": "npm run migrate -w @lf/db",
    "db:studio": "npm run studio -w @lf/db",
    "db:sql": "npm run sql -w @lf/db",
    "api:dev": "npm run dev -w @lf/api",
    "web:dev": "npm run dev -w @lf/web",
    "dev": "npm run db:generate && concurrently -n api,web -c blue,magenta \"npm run api:dev\" \"npm run web:dev\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
