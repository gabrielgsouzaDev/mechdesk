# ─────────────────────────────────────────────────────────────
# Banco de dados (Supabase / PostgreSQL)
# ─────────────────────────────────────────────────────────────
# Connection pooling (pgbouncer) — usado pela API em runtime
DATABASE_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Conexão direta — usada pelo Prisma Migrate (porta 5432)
DIRECT_URL="postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────
# Supabase (tempo real + auth)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_ANON_KEY="<anon-key>"
# NUNCA exponha a service role no frontend — só na API
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# ─────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────
API_PORT=3333
# Origens permitidas no CORS (produção: o domínio do front)
CORS_ORIGINS="http://localhost:5173"

# ─────────────────────────────────────────────────────────────
# Frontend (Vite — só variáveis VITE_* chegam ao browser)
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://<ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<anon-key>"
VITE_API_URL="http://localhost:3333"
